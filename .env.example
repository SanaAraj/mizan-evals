# mizan-evals environment
#
# None of these are required for the mock backend used in the tests and the
# quickstart. Provide only the keys for the real backends your run config
# references (those backends arrive in later milestones).

# OpenAI-compatible endpoint (frontier reference model or a local server)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (frontier reference model; backend not implemented yet - roadmap)
ANTHROPIC_API_KEY=

# Hugging Face (open-weight models such as ALLaM, Qwen, Jais)
HF_TOKEN=
